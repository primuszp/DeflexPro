<Window x:Class="DeflexPro.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:view="clr-namespace:DeflexPro.View"
        xmlns:control="clr-namespace:DeflexPro.Controls"
        Title="DeflexPro"
        Width="1440" Height="900"
        MinWidth="1100" MinHeight="700"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#0B1220"
        Foreground="#F0F6FF"
        FontFamily="Segoe UI"
        DataContext="{Binding Main, Source={StaticResource Locator}}">
    <Grid Background="#0B1220">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="224"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <control:NavigationPane Grid.Column="0"/>

        <!-- Dashboard page -->
        <Grid Grid.Column="1" Background="#0B1220"
              Visibility="{Binding IsDashboard, Converter={StaticResource BoolToVisConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header bar -->
            <Border Background="#0B1220" Padding="28,20,28,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{DynamicResource DashboardTitle}" FontSize="26" FontWeight="SemiBold"
                                   Foreground="#F0F6FF"/>
                        <TextBlock Text="{Binding FwdDetails.FileName}"
                                   Foreground="#8BA4C8" FontSize="13" Margin="0,4,0,0"/>
                    </StackPanel>
                    <Border Grid.Column="1" Background="#142038" BorderBrush="#2E4470" BorderThickness="1"
                            CornerRadius="10" Padding="14,8" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Fill="#26C6A3" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding FwdDetails.FormatName}" FontWeight="SemiBold"
                                       Foreground="#F0F6FF"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <view:BrowseFwdView Grid.Row="1" Margin="28,16,28,24" DataContext="{Binding FwdDetails}"/>
        </Grid>

        <!-- Backcalculation page -->
        <Grid Grid.Column="1" Background="#0B1220"
              Visibility="{Binding IsBackcalc, Converter={StaticResource BoolToVisConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header bar -->
            <Border Background="#0B1220" Padding="28,20,28,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{DynamicResource BackcalcTitle}" FontSize="26" FontWeight="SemiBold"
                                   Foreground="#F0F6FF"/>
                        <TextBlock Text="{DynamicResource BackcalcSubtitle}"
                                   Foreground="#8BA4C8" FontSize="13" Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- Sub-page tab buttons -->
                    <Border Grid.Column="1" Background="#142038" BorderBrush="#2E4470" BorderThickness="1"
                            CornerRadius="10" Padding="4" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <Button Command="{Binding Backcalc.GoLayerEditor}" Content="{DynamicResource LayerStructureTab}"
                                    Style="{Binding Backcalc.IsLayerEditorPage, Converter={StaticResource BoolToTabButtonConverter}}"
                                    Margin="0,0,4,0"/>
                            <Button Command="{Binding Backcalc.GoRun}" Content="{DynamicResource BackcalcTab}"
                                    Style="{Binding Backcalc.IsRunPage, Converter={StaticResource BoolToTabButtonConverter}}"
                                    Margin="0,0,4,0"/>
                            <Button Command="{Binding Backcalc.GoResults}" Content="{DynamicResource ResultsTab}"
                                    Style="{Binding Backcalc.IsResultsPage, Converter={StaticResource BoolToTabButtonConverter}}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <view:BackcalcView Grid.Row="1" Margin="28,16,28,24" DataContext="{Binding Backcalc}"/>
        </Grid>
    </Grid>
</Window>
