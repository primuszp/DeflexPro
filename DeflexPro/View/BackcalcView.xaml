<UserControl x:Class="DeflexPro.View.BackcalcView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <!-- ═══════════════════════════════════════════════════════════
             SUB-PAGE 1: PÁLYASZERKEZET SZERKESZTŐ
             ═══════════════════════════════════════════════════════════ -->
        <Grid Visibility="{Binding IsLayerEditorPage, Converter={StaticResource BoolToVisConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="260"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: Szelvény lista -->
            <Border Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="{DynamicResource Stations}" Style="{StaticResource EyebrowTextStyle}"/>
                        <TextBlock Text="{DynamicResource AssignLayerStructure}" FontSize="14" FontWeight="SemiBold" Margin="0,4,0,0"/>
                    </StackPanel>

                    <UniformGrid Grid.Row="2" Columns="2">
                        <Button Content="{DynamicResource All}" Command="{Binding SelectAllStations}"
                                Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,4,0" FontSize="11"/>
                        <Button Content="{DynamicResource None}" Command="{Binding ClearStationSelection}"
                                Style="{StaticResource SecondaryButtonStyle}" Margin="4,0,0,0" FontSize="11"/>
                    </UniformGrid>

                    <ListBox Grid.Row="4" ItemsSource="{Binding Stations}"
                             SelectedItem="{Binding SelectedStation}"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,0,0,4"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Root" Background="Transparent" CornerRadius="8" Padding="8,7">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Root" Property="Background" Value="{StaticResource CardHoverBrush}"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Root" Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                              VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding ShortName}" FontWeight="SemiBold" FontSize="13"/>
                                        <TextBlock Text="{Binding GroupName}" FontSize="10"
                                                   Foreground="{StaticResource PrimaryBrush}"
                                                   Visibility="{Binding HasGroup, Converter={StaticResource BoolToVisConverter}}"/>
                                    </StackPanel>
                                    <Ellipse Grid.Column="2" Width="7" Height="7" Margin="4,0,0,0"
                                             Fill="{StaticResource PrimaryBrush}"
                                             Visibility="{Binding HasResult, Converter={StaticResource BoolToVisConverter}}"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Group assignment -->
                    <Border Grid.Row="6" Background="{StaticResource CardHoverBrush}" CornerRadius="8" Padding="10">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Group}" Style="{StaticResource EyebrowTextStyle}" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding GroupNameInput, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource InputStyle}"
                                     Margin="0,0,0,6"/>
                            <UniformGrid Columns="2">
                                <Button Content="{DynamicResource Assign}" Command="{Binding AssignGroupCommand}"
                                        Style="{StaticResource PrimaryButtonStyle}" Padding="6,6" FontSize="11"
                                        Margin="0,0,4,0"/>
                                <Button Content="{DynamicResource Clear}" Command="{Binding ClearGroupCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}" Padding="6,6" FontSize="11"
                                        Margin="4,0,0,0"/>
                            </UniformGrid>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- CENTER: Réteg szerkesztő -->
            <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="14"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="{DynamicResource LayerEditor}" Style="{StaticResource EyebrowTextStyle}"/>
                            <TextBlock Text="{Binding SelectedStationLabel}" FontSize="16" FontWeight="SemiBold" Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                            <Button Content="{DynamicResource AddLayer}" Command="{Binding AddLayerCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}" Padding="10,6" Margin="0,0,8,0"/>
                            <Button Content="{DynamicResource RemoveLayer}" Command="{Binding RemoveLayerCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}" Padding="10,6"/>
                        </StackPanel>
                    </Grid>

                    <!-- Column headers -->
                    <Grid Grid.Row="2" Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="30"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="#" Style="{StaticResource EyebrowTextStyle}" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{DynamicResource MaterialLayer}" Style="{StaticResource EyebrowTextStyle}" Margin="8,0,0,0"/>
                        <TextBlock Grid.Column="2" Text="{DynamicResource Thickness}" Style="{StaticResource EyebrowTextStyle}" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="{DynamicResource SeedModulus}" Style="{StaticResource EyebrowTextStyle}" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="4" Text="E MIN (MPa)" Style="{StaticResource EyebrowTextStyle}" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="5" Text="E MAX (MPa)" Style="{StaticResource EyebrowTextStyle}" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="6" Text="{DynamicResource Fixed}" Style="{StaticResource EyebrowTextStyle}" HorizontalAlignment="Center"/>
                    </Grid>

                    <!-- Layer rows -->
                    <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding SelectedStation.Layers}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,6" CornerRadius="10" Padding="10,8">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{StaticResource CardHoverBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsHalfspace}" Value="True">
                                                        <Setter Property="Background" Value="#132E1F"/>
                                                        <Setter Property="BorderBrush" Value="#26C6A3"/>
                                                        <Setter Property="BorderThickness" Value="1"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="30"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="60"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Index indicator -->
                                            <Border Width="22" Height="22" CornerRadius="6"
                                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{StaticResource BorderBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsHalfspace}" Value="True">
                                                                <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="∞" FontSize="12" FontWeight="Bold"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           Visibility="{Binding IsHalfspace, Converter={StaticResource BoolToVisConverter}}"
                                                           Foreground="#071711"/>
                                            </Border>

                                            <!-- Material name -->
                                            <TextBox Grid.Column="1" Text="{Binding MaterialName, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource InputStyle}" Margin="8,0,8,0"
                                                     FontWeight="SemiBold"/>

                                            <!-- Thickness -->
                                            <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding ThicknessDisplay}" FontWeight="SemiBold"
                                                           HorizontalAlignment="Center" FontSize="13"
                                                           Visibility="{Binding IsHalfspace, Converter={StaticResource BoolToVisConverter}}"/>
                                                <TextBox Text="{Binding Thickness, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:0}}"
                                                         Style="{StaticResource InputStyle}" TextAlignment="Center" Width="70"
                                                         Visibility="{Binding IsHalfspace, Converter={StaticResource InverseBoolToVisConverter}}"/>
                                            </StackPanel>

                                            <!-- Seed Modulus -->
                                            <TextBox Grid.Column="3" Text="{Binding SeedModulus, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:0}}"
                                                     Style="{StaticResource InputStyle}" TextAlignment="Center" Margin="4,0"/>

                                            <!-- Min Modulus -->
                                            <TextBox Grid.Column="4" Text="{Binding MinModulus, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:0}}"
                                                     Style="{StaticResource InputStyle}" TextAlignment="Center" Margin="4,0"/>

                                            <!-- Max Modulus -->
                                            <TextBox Grid.Column="5" Text="{Binding MaxModulus, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:0}}"
                                                     Style="{StaticResource InputStyle}" TextAlignment="Center" Margin="4,0"/>

                                            <!-- Fixed -->
                                            <CheckBox Grid.Column="6" IsChecked="{Binding IsFixed}"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Layer structure legend -->
                    <Border Grid.Row="6" Background="{StaticResource CardHoverBrush}" CornerRadius="8" Padding="12,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{DynamicResource LayerCount}" Style="{StaticResource MutedTextStyle}"/>
                            <TextBlock Text="{Binding SelectedStation.Layers.Count, FallbackValue=0}"
                                       FontWeight="SemiBold" Margin="4,0,20,0"/>
                            <TextBlock Text="{DynamicResource TotalThickness}" Style="{StaticResource MutedTextStyle}"/>
                            <TextBlock FontWeight="SemiBold" Margin="4,0,0,0">
                                <TextBlock.Text>
                                    <Binding Path="SelectedStation.Layers" FallbackValue="–"/>
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- RIGHT: Apply options -->
            <Border Grid.Column="4" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="{DynamicResource Apply}" Style="{StaticResource EyebrowTextStyle}"/>
                        <TextBlock Text="{DynamicResource ApplyLayerStructure}" FontSize="14" FontWeight="SemiBold" Margin="0,4,0,0"/>
                        <TextBlock Text="{DynamicResource ApplyDescription}"
                                   Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" Margin="0,6,0,0"/>
                    </StackPanel>

                    <!-- Apply mode -->
                    <StackPanel Grid.Row="2">
                        <TextBlock Text="{DynamicResource ApplyScope}" Style="{StaticResource EyebrowTextStyle}" Margin="0,0,0,8"/>

                        <Border Background="{StaticResource CardHoverBrush}" CornerRadius="8" Padding="10" Margin="0,0,0,6">
                            <RadioButton IsChecked="{Binding ApplyToRange, Converter={StaticResource InverseBoolConverter}}"
                                         GroupName="ApplyMode" Foreground="{StaticResource TextBrush}" Cursor="Hand">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource SelectedStations}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{DynamicResource SelectedStationsDescription}"
                                               Style="{StaticResource MutedTextStyle}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </RadioButton>
                        </Border>

                        <Border Background="{StaticResource CardHoverBrush}" CornerRadius="8" Padding="10">
                            <StackPanel>
                                <RadioButton IsChecked="{Binding ApplyToRange}"
                                             GroupName="ApplyMode" Foreground="{StaticResource TextBrush}" Cursor="Hand">
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource StationRange}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{DynamicResource DistanceFilter}"
                                                   Style="{StaticResource MutedTextStyle}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </RadioButton>

                                <Grid Margin="22,8,0,0"
                                      IsEnabled="{Binding ApplyToRange}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource StartMeters}" Style="{StaticResource EyebrowTextStyle}" Margin="0,0,0,4"/>
                                        <TextBox Text="{Binding ApplyRangeFrom, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource InputStyle}" TextAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="{DynamicResource EndMeters}" Style="{StaticResource EyebrowTextStyle}" Margin="0,0,0,4"/>
                                        <TextBox Text="{Binding ApplyRangeTo, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource InputStyle}" TextAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Preset structures -->
                    <StackPanel Grid.Row="4">
                        <TextBlock Text="{DynamicResource QuickTemplates}" Style="{StaticResource EyebrowTextStyle}" Margin="0,0,0,8"/>
                        <Button Content="{DynamicResource TemplateAcCtbSubgrade}" Style="{StaticResource SecondaryButtonStyle}"
                                HorizontalContentAlignment="Left" Padding="10,7" Margin="0,0,0,5"/>
                        <Button Content="{DynamicResource TemplateAcKaSubgrade}" Style="{StaticResource SecondaryButtonStyle}"
                                HorizontalContentAlignment="Left" Padding="10,7" Margin="0,0,0,5"/>
                        <Button Content="{DynamicResource TemplateAsphaltSubgrade}" Style="{StaticResource SecondaryButtonStyle}"
                                HorizontalContentAlignment="Left" Padding="10,7"/>
                    </StackPanel>

                    <Button Grid.Row="6" Content="{DynamicResource ApplyArrow}" Command="{Binding ApplyLayersCommand}"
                            Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Stretch"/>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════
             SUB-PAGE 2: VISSZASZÁMÍTÁS FUTTATÁSA
             ═══════════════════════════════════════════════════════════ -->
        <Grid Visibility="{Binding IsRunPage, Converter={StaticResource BoolToVisConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: Station status list -->
            <Border Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Stations}" Style="{StaticResource EyebrowTextStyle}"/>
                        <TextBlock Text="{DynamicResource StationsToRun}" FontSize="14" FontWeight="SemiBold" Margin="0,4,0,0"/>
                    </StackPanel>
                    <UniformGrid Grid.Row="2" Columns="2">
                        <Button Content="{DynamicResource All}" Command="{Binding SelectAllStations}"
                                Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,4,0" FontSize="11"/>
                        <Button Content="{DynamicResource None}" Command="{Binding ClearStationSelection}"
                                Style="{StaticResource SecondaryButtonStyle}" Margin="4,0,0,0" FontSize="11"/>
                    </UniformGrid>
                    <ListBox Grid.Row="4" ItemsSource="{Binding Stations}" ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="6,5" Margin="0,0,0,3">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1" Margin="8,0">
                                            <TextBlock Text="{Binding ShortName}" FontWeight="SemiBold" FontSize="12"/>
                                            <TextBlock Text="{Binding ResultSummary}" FontSize="10"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       Visibility="{Binding HasResult, Converter={StaticResource BoolToVisConverter}}"/>
                                        </StackPanel>
                                        <Border Grid.Column="2" Width="8" Height="8" CornerRadius="4">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{StaticResource BorderBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasResult}" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- CENTER: Settings + Run -->
            <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="20"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="20"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="20"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="{DynamicResource BackcalcSettings}" Style="{StaticResource EyebrowTextStyle}"/>
                        <TextBlock Text="{DynamicResource MethodAndParameters}" FontSize="16" FontWeight="SemiBold" Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- Számítási mód -->
                    <StackPanel Grid.Row="2">
                        <TextBlock Text="{DynamicResource CalculationMode}" Style="{StaticResource EyebrowTextStyle}" Margin="0,0,0,10"/>
                        <UniformGrid Columns="2">
                            <Border CornerRadius="10" Padding="14,12" Margin="0,0,6,0" Cursor="Hand">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{StaticResource CardHoverBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding UseGroupMode}" Value="False">
                                                <Setter Property="Background" Value="#0F3323"/>
                                                <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                                <Setter Property="BorderThickness" Value="1.5"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                    <RadioButton IsChecked="{Binding UseGroupMode, Converter={StaticResource InverseBoolConverter}}"
                                                 GroupName="CalcMode" Foreground="{StaticResource TextBrush}" Cursor="Hand">
                                        <StackPanel>
                                            <TextBlock Text="{DynamicResource Individual}" FontWeight="Bold" FontSize="14"/>
                                            <TextBlock Text="{DynamicResource IndividualDescription}"
                                                       Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </RadioButton>
                                </StackPanel>
                            </Border>
                            <Border CornerRadius="10" Padding="14,12" Margin="6,0,0,0" Cursor="Hand">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{StaticResource CardHoverBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding UseGroupMode}" Value="True">
                                                <Setter Property="Background" Value="#0F3323"/>
                                                <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                                <Setter Property="BorderThickness" Value="1.5"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                    <RadioButton IsChecked="{Binding UseGroupMode}"
                                                 GroupName="CalcMode" Foreground="{StaticResource TextBrush}" Cursor="Hand">
                                        <StackPanel>
                                            <TextBlock Text="{DynamicResource Grouped}" FontWeight="Bold" FontSize="14"/>
                                            <TextBlock Text="{DynamicResource GroupedDescription}"
                                                       Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </RadioButton>
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </StackPanel>

                    <!-- Algoritmus -->
                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Algorithm}" Style="{StaticResource EyebrowTextStyle}" Margin="0,0,0,6"/>
                            <ComboBox ItemsSource="{Binding Methods}"
                                      SelectedIndex="{Binding SelectedMethodIndex}"
                                      Style="{StaticResource ComboBoxStyle}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{DynamicResource PlateRadiusMm}" Style="{StaticResource EyebrowTextStyle}" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding PlateRadius, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:0}}"
                                     Style="{StaticResource InputStyle}" TextAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <!-- Summary stats -->
                    <Border Grid.Row="6" Background="{StaticResource CardHoverBrush}" CornerRadius="10" Padding="14,10">
                        <UniformGrid Columns="3">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{Binding Stations.Count}" FontSize="22" FontWeight="Bold"
                                           HorizontalAlignment="Center" Foreground="{StaticResource TextBrush}"/>
                                <TextBlock Text="{DynamicResource TotalStations}" Style="{StaticResource MutedTextStyle}"
                                           HorizontalAlignment="Center" TextAlignment="Center"/>
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{Binding SelectedCount}" FontSize="22" FontWeight="Bold"
                                           HorizontalAlignment="Center" Foreground="{StaticResource PrimaryBrush}"/>
                                <TextBlock Text="{DynamicResource Selected}" Style="{StaticResource MutedTextStyle}"
                                           HorizontalAlignment="Center" TextAlignment="Center"/>
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{Binding ResultCount}" FontSize="22" FontWeight="Bold"
                                           HorizontalAlignment="Center" Foreground="{StaticResource TextBrush}"/>
                                <TextBlock Text="{DynamicResource CompletedResults}" Style="{StaticResource MutedTextStyle}"
                                           HorizontalAlignment="Center" TextAlignment="Center"/>
                            </StackPanel>
                        </UniformGrid>
                    </Border>

                    <!-- Run button -->
                    <Button Grid.Row="8" Command="{Binding RunCommand}" HorizontalAlignment="Stretch"
                            Style="{StaticResource PrimaryButtonStyle}" FontSize="15" Padding="0,14">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="▶  " FontSize="16"/>
                            <TextBlock Text="{DynamicResource StartBackcalc}" FontSize="15" FontWeight="Bold"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- RIGHT: Progress vizualizáció + log -->
            <Border Grid.Column="4" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- fejléc -->
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>  <!-- overall progress -->
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>  <!-- RMSE + iteráció progress -->
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>  <!-- aktuális szelvény név -->
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>     <!-- log -->
                    </Grid.RowDefinitions>

                    <!-- Fejléc -->
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Log}" Style="{StaticResource EyebrowTextStyle}"/>
                        <TextBlock Text="{DynamicResource RunProgress}" FontSize="14" FontWeight="SemiBold" Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- Overall: Szelvény-szintű haladás -->
                    <Border Grid.Row="2" Background="{StaticResource CardHoverBrush}" CornerRadius="9" Padding="12,10">
                        <StackPanel>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="SZELVÉNYEK" Style="{StaticResource EyebrowTextStyle}"/>
                                <TextBlock Grid.Column="1" Text="{Binding OverallCountDisplay}"
                                           FontWeight="Bold" FontSize="13"
                                           Foreground="{StaticResource PrimaryBrush}"/>
                            </Grid>
                            <ProgressBar Value="{Binding OverallPercent, Mode=OneWay}" Minimum="0" Maximum="100"
                                         Height="12" Foreground="{StaticResource PrimaryBrush}"
                                         Background="{StaticResource InputBrush}" BorderThickness="0"/>
                            <TextBlock Text="{Binding OverallPercent, StringFormat={}{0:0} %}"
                                       HorizontalAlignment="Right" FontSize="11" Margin="0,4,0,0"
                                       Foreground="{StaticResource MutedTextBrush}"/>
                        </StackPanel>
                    </Border>

                    <!-- Per-szelvény: iteráció + RMSE -->
                    <Border Grid.Row="4" Background="{StaticResource CardHoverBrush}" CornerRadius="9" Padding="12,10">
                        <StackPanel>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="ITERÁCIÓ" Style="{StaticResource EyebrowTextStyle}"/>
                                <TextBlock Grid.Column="1" Text="{Binding ProgressCountDisplay}"
                                           FontWeight="SemiBold" FontSize="12"
                                           Foreground="{StaticResource MutedTextBrush}"/>
                            </Grid>
                            <ProgressBar Value="{Binding ProgressPercent, Mode=OneWay}" Minimum="0" Maximum="100"
                                         Height="7" Foreground="#26C6A3"
                                         Background="{StaticResource InputBrush}" BorderThickness="0" Opacity="0.7"/>
                            <!-- RMSE nagybetűs kijelzés -->
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="RMSE" Style="{StaticResource EyebrowTextStyle}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding LastRmseDisplay}"
                                           FontSize="20" FontWeight="Bold"
                                           Foreground="{StaticResource PrimaryBrush}"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Aktuális szelvény neve -->
                    <Border Grid.Row="6" Background="#0B1220" CornerRadius="7" Padding="10,7">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Ellipse Width="8" Height="8" Fill="{StaticResource PrimaryBrush}"
                                     VerticalAlignment="Center" Margin="0,0,8,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Opacity" Value="0"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                <Setter Property="Opacity" Value="1"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding ProgressStatus}"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       FontSize="11" FontFamily="Consolas"
                                       TextTrimming="CharacterEllipsis"/>
                        </Grid>
                    </Border>

                    <!-- Konzol log -->
                    <ScrollViewer Grid.Row="8" VerticalScrollBarVisibility="Auto">
                        <TextBox Text="{Binding ProgressLog}" IsReadOnly="True" TextWrapping="Wrap"
                                 TextChanged="ProgressLogTextBox_OnTextChanged"
                                 Background="Transparent" BorderThickness="0"
                                 Foreground="{StaticResource MutedTextBrush}"
                                 FontFamily="Consolas" FontSize="11"
                                 VerticalAlignment="Top"/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════
             SUB-PAGE 3: EREDMÉNYEK
             ═══════════════════════════════════════════════════════════ -->
        <Grid Visibility="{Binding IsResultsPage, Converter={StaticResource BoolToVisConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Summary cards -->
            <UniformGrid Columns="4">
                <Border Style="{StaticResource CardStyle}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Processed}" Style="{StaticResource EyebrowTextStyle}"/>
                        <TextBlock Text="{Binding ResultCount}" FontSize="28" FontWeight="SemiBold" Margin="0,7,0,0"/>
                        <TextBlock Text="{DynamicResource BackcalculatedStations}" Style="{StaticResource MutedTextStyle}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardStyle}" Margin="4,0,8,0">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource AverageRmse}" Style="{StaticResource EyebrowTextStyle}"/>
                        <TextBlock Text="–" FontSize="28" FontWeight="SemiBold" Margin="0,7,0,0"/>
                        <TextBlock Text="{DynamicResource FitError}" Style="{StaticResource MutedTextStyle}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardStyle}" Margin="8,0,4,0">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource MinSubgrade}" Style="{StaticResource EyebrowTextStyle}"/>
                        <TextBlock Text="–" FontSize="28" FontWeight="SemiBold" Margin="0,7,0,0"/>
                        <TextBlock Text="MPa" Style="{StaticResource MutedTextStyle}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardStyle}" Margin="12,0,0,0">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource MaxSubgrade}" Style="{StaticResource EyebrowTextStyle}"/>
                        <TextBlock Text="–" FontSize="28" FontWeight="SemiBold" Margin="0,7,0,0"/>
                        <TextBlock Text="MPa" Style="{StaticResource MutedTextStyle}"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Results data grid -->
            <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Padding="16,12" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{DynamicResource BackcalcResults}" Style="{StaticResource EyebrowTextStyle}"/>
                                <TextBlock Text="{DynamicResource LayerModuliByStation}" FontSize="15" FontWeight="SemiBold" Margin="0,4,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="{DynamicResource ExportCsv}" Command="{Binding ExportResultsCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}" Padding="14,8"/>
                        </Grid>
                    </Border>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding ResultRows}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              Style="{StaticResource ResultsDataGridStyle}"
                              ColumnHeaderStyle="{StaticResource DataGridColumnHeaderStyle}"
                              CellStyle="{StaticResource DataGridCellStyle}"
                              RowStyle="{StaticResource DataGridRowStyle}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{DynamicResource StationMeters}" Binding="{Binding Distance, StringFormat={}{0:0.00}}" Width="110"/>
                            <DataGridTextColumn Header="{DynamicResource Group}" Binding="{Binding GroupName}" Width="90"/>
                            <DataGridTextColumn Header="E₁ (MPa)" Binding="{Binding Result.LayerModuli[0], StringFormat={}{0:0}, FallbackValue=–}" Width="90"/>
                            <DataGridTextColumn Header="E₂ (MPa)" Binding="{Binding Result.LayerModuli[1], StringFormat={}{0:0}, FallbackValue=–}" Width="90"/>
                            <DataGridTextColumn Header="E₃ (MPa)" Binding="{Binding Result.LayerModuli[2], StringFormat={}{0:0}, FallbackValue=–}" Width="90"/>
                            <DataGridTextColumn Header="{DynamicResource SubgradeModulus}" Binding="{Binding Result.SubgradeModulus, StringFormat={}{0:0}, FallbackValue=–}" Width="120"/>
                            <DataGridTextColumn Header="RMSE (%)" Binding="{Binding RmseDisplay}" Width="90"/>
                            <DataGridTextColumn Header="SCI (μm)" Binding="{Binding Result.SCI, StringFormat={}{0:0.0}, FallbackValue=–}" Width="90"/>
                            <DataGridTextColumn Header="BDI (μm)" Binding="{Binding Result.BDI, StringFormat={}{0:0.0}, FallbackValue=–}" Width="90"/>
                            <DataGridTextColumn Header="BCI (μm)" Binding="{Binding Result.BCI, StringFormat={}{0:0.0}, FallbackValue=–}" Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Export bar -->
            <Border Grid.Row="4" Style="{StaticResource CardStyle}" Padding="14,10">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{DynamicResource SelectedStationResult}" Style="{StaticResource MutedTextStyle}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding SelectedStation.ResultSummary, FallbackValue=Nincs kijelölve}"
                               FontWeight="SemiBold" VerticalAlignment="Center" Margin="6,0,0,0"/>
                    <TextBlock Text="{Binding SelectedStation.RmseDisplay}"
                               Style="{StaticResource MutedTextStyle}" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
