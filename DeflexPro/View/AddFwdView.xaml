<UserControl x:Class="DeflexPro.View.AddFwdView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource CardStyle}">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="420">
            <Border Width="64" Height="64" Background="{StaticResource CardHoverBrush}" CornerRadius="16">
                <Image Source="/DeflexPro;component/Images/Navigation/import.png" Width="30" Height="30"/>
            </Border>
            <TextBlock Text="{DynamicResource ImportTitle}" FontSize="22" FontWeight="SemiBold"
                       HorizontalAlignment="Center" Margin="0,18,0,0"/>
            <TextBlock Text="{DynamicResource ImportDescription}"
                       Style="{StaticResource MutedTextStyle}" TextAlignment="Center" TextWrapping="Wrap"
                       Margin="0,8,0,20"/>
            <Button Content="{DynamicResource SelectFile}" Command="{Binding LoadFwdMachine}"
                    Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Center"/>
        </StackPanel>
    </Border>
</UserControl>
