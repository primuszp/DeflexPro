<UserControl x:Class="DeflexPro.View.BrowseFwdView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:view="clr-namespace:DeflexPro.View"
             xmlns:oxy="clr-namespace:OxyPlot.Wpf;assembly=OxyPlot.Wpf">
    <Grid>
        <Grid.RowDefinitions>
            <!-- Kompakt stat-sáv -->
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <!-- Fő tartalom – teljes maradék magasság -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ════════════════════════════════════════════════
             SOR 0 – Kompakt statisztika-sáv
             ════════════════════════════════════════════════ -->
        <Border Background="{StaticResource SidebarBrush}" CornerRadius="10" Padding="16,10">
            <UniformGrid Columns="5">

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                    <TextBlock Text="{Binding StationCount}" FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center"/>
                    <StackPanel Margin="8,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="SZELVÉNY" Style="{StaticResource EyebrowTextStyle}"/>
                        <TextBlock Text="mérési hely" Foreground="#8BA4C8" FontSize="11"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                    <TextBlock Text="{Binding DropCount}" FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center"/>
                    <StackPanel Margin="8,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="EJTÉS" Style="{StaticResource EyebrowTextStyle}"/>
                        <TextBlock Text="feldolgozott mérés" Foreground="#8BA4C8" FontSize="11"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                    <TextBlock Text="{Binding SensorCount}" FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center"/>
                    <StackPanel Margin="8,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="SZENZOR" Style="{StaticResource EyebrowTextStyle}"/>
                        <TextBlock Text="csatorna" Foreground="#8BA4C8" FontSize="11"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                    <TextBlock Text="{Binding PlateRadius, StringFormat={}{0:0} mm}" FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center"/>
                    <StackPanel Margin="8,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="TÁNYÉR" Style="{StaticResource EyebrowTextStyle}"/>
                        <TextBlock Text="terhelőlemez sugár" Foreground="#8BA4C8" FontSize="11"/>
                    </StackPanel>
                </StackPanel>

                <!-- Szenzor offset badge-ek -->
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="SZENZOR OFFSETEK" Style="{StaticResource EyebrowTextStyle}" Margin="0,0,0,4"/>
                    <ItemsControl ItemsSource="{Binding Sensors}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#0B1220" CornerRadius="4" Padding="5,2" Margin="0,0,4,3">
                                    <TextBlock FontSize="11" FontWeight="SemiBold">
                                        <Run Text="{Binding X, StringFormat={}{0:0}}" Foreground="#26C6A3"/>
                                        <Run Text="mm" Foreground="#8BA4C8"/>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

            </UniformGrid>
        </Border>

        <!-- ════════════════════════════════════════════════
             SOR 2 – Fő tartalom (3 oszlop)
             ════════════════════════════════════════════════ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <!-- Szelvénylista -->
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="12"/>
                <!-- Behajlási diagram -->
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <!-- Jobb panel: ejtés-választó + részletek -->
                <ColumnDefinition Width="340"/>
            </Grid.ColumnDefinitions>

            <!-- ── Bal: Szelvénylista ── -->
            <Border Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel>
                        <TextBlock Text="SZELVÉNYEK" Style="{StaticResource EyebrowTextStyle}"/>
                        <TextBlock Text="Mérési hely kiválasztása" FontSize="14" FontWeight="SemiBold" Margin="0,4,0,0"/>
                    </StackPanel>
                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding Stations}"
                             SelectedItem="{Binding SelectedStation}"
                             ItemContainerStyle="{StaticResource StationItemStyle}"
                             DisplayMemberPath="DisplayName"/>
                </Grid>
            </Border>

            <!-- ── Közép: Behajlási görbe ── -->
            <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="8">
                <oxy:PlotView x:Name="graph" Model="{Binding Plot.Model}" Background="Transparent"/>
            </Border>

            <!-- ── Jobb: Ejtés-választó + Ejtés részletek ── -->
            <Border Grid.Column="4" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>   <!-- 0: fejléc + gombok      -->
                        <RowDefinition Height="10"/>     <!-- 1: gap                  -->
                        <RowDefinition Height="Auto" MaxHeight="220"/> <!-- 2: ejtés-lista -->
                        <RowDefinition Height="12"/>     <!-- 3: gap                  -->
                        <RowDefinition Height="Auto"/>   <!-- 4: elválasztó + felirat -->
                        <RowDefinition Height="10"/>     <!-- 5: gap                  -->
                        <RowDefinition Height="*"/>      <!-- 6: TemperatureView-k    -->
                    </Grid.RowDefinitions>

                    <!-- Fejléc + gombok (Row 0) -->
                    <StackPanel>
                        <TextBlock Text="EJTÉSVÁLASZTÓ" Style="{StaticResource EyebrowTextStyle}"/>
                        <Grid Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Content="Mind" Command="{Binding SelectAllDrops}"
                                    Style="{StaticResource SecondaryButtonStyle}"/>
                            <Button Grid.Column="2" Content="Egyik sem" Command="{Binding ClearDropSelection}"
                                    Style="{StaticResource SecondaryButtonStyle}"/>
                        </Grid>
                    </StackPanel>

                    <!-- Ejtés-lista checkboxokkal (Row 2) -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding SelectedDrops}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource CardHoverBrush}" CornerRadius="7"
                                            Padding="9,7" Margin="0,0,0,5">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                      VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="1" Margin="9,0">
                                                <TextBlock Text="{Binding ImpNumber, StringFormat=Ejtés #{0}}"
                                                           FontWeight="SemiBold" FontSize="13"/>
                                                <TextBlock Text="{Binding DateTime, StringFormat=HH:mm:ss}"
                                                           Style="{StaticResource MutedTextStyle}" FontSize="11"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding PeakForce, StringFormat={}{0:0.0} kN}"
                                                       Foreground="{StaticResource PrimaryBrush}"
                                                       FontWeight="SemiBold" FontSize="12"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Elválasztó + "MÉRÉSI RÉSZLETEK" felirat (Row 4) -->
                    <StackPanel Grid.Row="4" Orientation="Vertical">
                        <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,0,0,8"/>
                        <TextBlock Text="MÉRÉSI RÉSZLETEK" Style="{StaticResource EyebrowTextStyle}"/>
                    </StackPanel>

                    <!-- Scrollozható TemperatureView-k (Row 6) -->
                    <ScrollViewer Grid.Row="6"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding SelectedDrops}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <view:TemperatureView Margin="0,0,0,8"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                </Grid>
            </Border>
        </Grid>

    </Grid>
</UserControl>
